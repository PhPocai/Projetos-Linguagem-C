#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct lista{
    char codvoo[15];
    char data[11];
    char hora[6];
    struct lista *prox;
}LISTA;

typedef struct aviao {
    char nome[20];
    int lugares;
    LISTA *voo;
    struct aviao *prox;
} AVIAO;

typedef struct decolagem{
    char codigovoo[15];
    struct decolagem *prox;
}DECOLAGEM;

typedef struct aterisar{
    char codigovoo[15];
    struct aterisar *prox;
}ATERRISSAR;

AVIAO* buscaAviao(AVIAO *inicio, char nome[]){
    AVIAO *aux = inicio;

    while(aux != NULL){
        if(strcmp(aux->nome, nome) == 0){
            return aux;
        }
        aux = aux->prox;
    }

    return NULL;
}

int existeVoo(AVIAO *inicio, char codigo[]){
    AVIAO *aux = inicio;
    LISTA *v;

    while(aux != NULL){
        v = aux->voo;
        while(v != NULL){
            if(strcmp(v->codvoo, codigo) == 0){
                return 1;
            }
            v = v->prox;
        }
        aux = aux->prox;
    }
    return 0;
}

void insereAviao (char nome[], int lugares, AVIAO **inicio){
    AVIAO *novo;
    novo = (AVIAO*) malloc(sizeof(AVIAO));
    strcpy(novo->nome,nome);
    novo->lugares = lugares;
    novo->voo = NULL;
    novo->prox = NULL;
    if (*inicio == NULL){
       *inicio = novo;
       }else {
        novo->prox = *inicio;
        *inicio = novo;
    }
}

void insereVoo(AVIAO *n, char codigo[],char data[],char hora[]){
    LISTA *novo,*aux;
    novo = (LISTA*) malloc(sizeof(LISTA));

    strcpy(novo->codvoo,codigo);
    strcpy(novo->data,data);
    strcpy(novo->hora,hora);
    novo->prox = NULL;

    if(n->voo == NULL){
        n->voo = novo;
    }else{
        aux = n->voo;
        while(aux->prox != NULL){
            aux = aux->prox;
        }
        aux->prox = novo;
    }
}

void solicitaAterissagem(AVIAO *lista, char codigo[], ATERRISSAR **f){
    ATERRISSAR *novo,*aux;

     if(!existeVoo(lista, codigo)){
        printf("Voo nao cadastrado!\n");
        return;
    }

    novo = (ATERRISSAR*) malloc(sizeof(ATERRISSAR));

    strcpy(novo->codigovoo,codigo);
    novo->prox = NULL;

    if(*f == NULL){
        *f = novo;
    } else {
        aux = *f;
        while(aux->prox != NULL){
            aux = aux->prox;
        }
        aux->prox = novo;
    }
}


void aterissar (ATERRISSAR **f){
    ATERRISSAR *aux;

    if(*f == NULL){
        printf("Fila vazia\n");
        return;
    }

    aux = *f;
    printf("Aterrissou voo: %s\n", aux->codigovoo);

    *f = aux->prox;
    free(aux);

}

void solicitaDecolagem(AVIAO *lista, char codigo[], DECOLAGEM **f){
    DECOLAGEM *novo;

     if(!existeVoo(lista, codigo)){
        printf("Voo nao cadastrado!\n");
        return;
    }

    novo = (DECOLAGEM*) malloc(sizeof(DECOLAGEM));

    strcpy(novo->codigovoo, codigo);
    novo->prox = NULL;

    if(*f == NULL){
        *f = novo;
    } else {
        DECOLAGEM *aux = *f;
        while(aux->prox != NULL){
            aux = aux->prox;
        }
        aux->prox = novo;
    }
}

void decola(DECOLAGEM **f){
    DECOLAGEM *aux;

    if(*f == NULL){
        printf("Fila vazia\n");
        return;
    }

    aux = *f;
    printf("Decolou voo: %s\n", aux->codigovoo);

    *f = aux->prox;
    free(aux);
}

void exibeAviao(AVIAO *inicio){
    AVIAO *aux = inicio;

    while(aux != NULL){
        printf("Aviao: %s | Lugares: %d\n", aux->nome, aux->lugares);
        aux = aux->prox;
    }
}

void exibeVoo(AVIAO *inicio){
    AVIAO *aux = inicio;
    LISTA *v;
    while(aux != NULL){
        printf("\nAviao: %s\n", aux->nome);

        v = aux->voo;
        while(v != NULL){
            printf("Voo: %s | Data: %s | Hora: %s\n",v->codvoo, v->data, v->hora);v = v->prox;
        }
        aux = aux->prox;
    }
}

