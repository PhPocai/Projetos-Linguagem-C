    ATERRISSAR *aux = f;

    while(aux != NULL){
        printf("Voo: %s\n", aux->codigovoo);
        aux = aux->prox;
    }
}

void exibeFilaDc(DECOLAGEM *f){
    DECOLAGEM *aux = f;

    while(aux != NULL){
        printf("Voo: %s\n", aux->codigovoo);
        aux = aux->prox;
    }
}

void removeAviao(AVIAO **inicio, char nome[]){
    AVIAO *aux = *inicio;
    AVIAO *ant = NULL;

    while(aux != NULL && strcmp(aux->nome, nome) != 0){
        ant = aux;
        aux = aux->prox;
    }

    if(aux == NULL){
        printf("Aviao nao encontrado\n");
        return;
    }

    if(ant == NULL){
        *inicio = aux->prox;
    } else {
        ant->prox = aux->prox;
    }

    free(aux);
    printf("Aviao removido\n");
}

void removeVoo(AVIAO *inicio, char codigo[]){
    AVIAO *aux = inicio;
    LISTA *v,*ant;
    while(aux != NULL){
        v = aux->voo;
        ant = NULL;
        while(v != NULL && strcmp(v->codvoo, codigo) != 0){
            ant = v;
            v = v->prox;
        }

        if(v != NULL){
            if(ant == NULL){
                aux->voo = v->prox;
            } else {
                ant->prox = v->prox;
            }

            free(v);
            printf("Voo removido\n");
            return;
        }

        aux = aux->prox;
    }

    printf("Voo nao encontrado\n");
}


